generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  EMPLOYER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ShiftType {
  DAY
  NIGHT
  ROTATIONAL
  GENERAL
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum JobStatus {
  ACTIVE
  CLOSED
  EXPIRED
  SUSPENDED
}

enum AppStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  HIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentPurpose {
  PLAN_PURCHASE
  FEATURED_JOB
}

enum TargetType {
  JOB
  WORKER
  EMPLOYER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum NotifType {
  APPLICATION
  SHORTLIST
  HIRE
  REJECT
  SYSTEM
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  emailVerified Boolean     @default(false)
  phone         String?
  name          String?
  role          Role        @default(WORKER)
  city          String?
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())

  workerProfile   WorkerProfile?
  employerProfile EmployerProfile?
  jobs            Job[]
  applications    Application[]
  payments        Payment[]
  reports         Report[]
  notifications   Notification[]

  @@index([role])
  @@index([status])
  @@index([city])
  @@index([role, status])
  @@index([createdAt])
}

model WorkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  trade           String?
  experienceYears Int?
  expectedSalary  Int?
  availableFrom   DateTime?
  languages       String[]
  photoUrl        String?
  idDocUrl        String?
  isVerified      Boolean  @default(false)
  rating          Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trade])
  @@index([isVerified])
  @@index([trade, isVerified])
  @@index([experienceYears])
  @@index([isVerified, experienceYears])
  @@index([expectedSalary])
  @@index([rating])
}

model EmployerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String?
  industry      String?
  gstNumber     String?
  address       String?
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  rating        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobCredits JobCredit[]

  @@index([isVerified])
  @@index([industry])
  @@index([rating])
}

model Job {
  id          String    @id @default(cuid())
  employerId  String
  title       String
  description String?
  category    String?
  location    String?
  city        String    @default("Hyderabad")
  salaryMin   Int?
  salaryMax   Int?
  vacancies   Int       @default(1)
  shiftType   ShiftType @default(GENERAL)
  jobType     JobType   @default(FULL_TIME)
  status      JobStatus @default(ACTIVE)
  isFeatured  Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employer     User          @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]
  views        JobView[]

  @@index([employerId])
  @@index([status])
  @@index([category])
  @@index([city])
  @@index([shiftType])
  @@index([isFeatured])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([employerId, status])
  @@index([employerId, createdAt])
  @@index([status, category, city])
  @@index([status, shiftType])
  @@index([status, city, salaryMin])
  @@index([isFeatured, status])
  @@index([city, status])
  @@index([category, status])
}

model JobView {
  id        String   @id @default(cuid())
  jobId     String
  viewedAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([viewedAt])
  @@index([jobId, viewedAt])
}

model Application {
  id        String   @id @default(cuid())
  jobId     String
  workerId  String
  status    AppStatus @default(APPLIED)
  note      String?
  appliedAt DateTime @default(now())

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker User @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
  @@index([jobId])
  @@index([workerId])
  @@index([workerId, appliedAt])
  @@index([status])
  @@index([appliedAt])
  @@index([jobId, status])
  @@index([jobId, appliedAt])
}

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique
  price           Int
  durationDays    Int
  jobPostLimit    Int
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments Payment[]
}

model JobCredit {
  id              String   @id @default(cuid())
  employerId      String   @unique
  remaining       Int      @default(0)
  expiryDate      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employer EmployerProfile @relation(fields: [employerId], references: [userId], onDelete: Cascade)
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  planId            String?
  amount            Int
  status            PaymentStatus   @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  purpose           PaymentPurpose?
  createdAt         DateTime        @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([razorpayOrderId, status])
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  targetType  TargetType
  targetId    String
  reason      String
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType])
  @@index([targetId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotifType @default(SYSTEM)
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  @@index([name])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  @@index([name])
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  OTP_SENT
  OTP_VERIFIED
  JOB_CREATED
  JOB_UPDATED
  JOB_CLOSED
  JOB_DELETED
  APPLICATION_CREATED
  APPLICATION_UPDATED
  PAYMENT_INITIATED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  CREDIT_PURCHASED
  EMPLOYER_VERIFIED
  WORKER_VERIFIED
  ADMIN_APPROVAL
  ROLE_CHANGED
  PROFILE_UPDATED
  WEBHOOK_RECEIVED
  WEBHOOK_FAILED
  REPORT_CREATED
  REPORT_RESOLVED
  EXPORT
  SYSTEM
}

model AuditLog {
  id          String      @id @default(cuid())
  timestamp   DateTime    @default(now())
  actorId     String?
  actorRole   Role?
  action      AuditAction
  resource    String?
  resourceId  String?
  metadata    Json?
  oldValues   Json?
  newValues   Json?
  ip          String?
  userAgent   String?
  traceId     String?
  requestId   String?

  @@index([timestamp])
  @@index([actorId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([actorId, timestamp])
  @@index([action, timestamp])
}
