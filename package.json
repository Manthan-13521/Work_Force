{
  "name": "workforce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:invariants": "vitest run --config vitest.invariants.config.ts",
    "test:smoke": "k6 run tests/load/smoke-test.js && npm run test:certify",
    "test:certify": "npm run test:invariants -- --reporter=json > tests/reporting/certification-report.json 2>&1",
    "test:chaos:redis": "bash tests/chaos/redis-outage.sh",
    "test:chaos:db": "bash tests/chaos/db-latency.sh",
    "test:chaos": "npm run test:chaos:redis && npm run test:chaos:db && npm run test:certify",
    "test:all": "npm run test && npm run test:invariants && npm run test:smoke",
    "validate:integrations": "npx tsx scripts/validate-integrations.ts",
    "validate:production-env": "npx tsx scripts/validate-integrations.ts --strict",
    "sentry:test-event": "npx tsx scripts/sentry-test-event.ts",
    "verify:backup": "bash scripts/verify-backup.sh",
    "certify": "npm run test:certify && node tests/reporting/generate-report.mjs",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^10.65.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.510.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "posthog-js": "^1.399.1",
    "posthog-node": "^5.40.0",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
