# Database (PostgreSQL — local or hosted)
# Local: postgresql://postgres:password@localhost:5432/workforce
# Hosted (Neon/ Railway/ Supabase): postgresql://user:password@host:5432/workforce
DATABASE_URL="postgresql://user@localhost:5432/workforce"

# JWT — must be at least 32 characters
JWT_SECRET="your-jwt-secret-here"

# MSG91 for OTP
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="WRKFRC"
MSG91_TEMPLATE_ID="your-otp-template-id"

# Cloudinary for uploads
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Razorpay
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"

# Redis / Upstash for OTP storage and rate limiting
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Sentry (error monitoring)
# SENTRY_DSN="https://key@oorg.ingest.sentry.io/project"

# Environment
# NODE_ENV="development"
