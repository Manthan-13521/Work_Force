# Database (PostgreSQL — local or hosted)
# Local: postgresql://postgres:password@localhost:5432/workforce
# Hosted (Neon/ Railway/ Supabase): postgresql://user:password@host:5432/workforce
DATABASE_URL="postgresql://user@localhost:5432/workforce"

# JWT — must be at least 32 characters
JWT_SECRET="your-jwt-secret-here"

# Resend (Transactional Email for OTP)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_REPLY_TO="support@yourdomain.com"

# Cloudinary for uploads
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Razorpay
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# App (REQUIRED in production — CSRF origin validation, sitemap, redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"

# Redis / Upstash for OTP storage and rate limiting
UPSTASH_REDIS_REST_URL="https://supreme-lab-86990.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAVPOAAIgcDIwYzRjOTE3YzYyMzY0ZTAxOWMyYzExZWI0MGVjYzI2NA"


# Sentry (error monitoring — configure in production)
SENTRY_DSN="https://key@oorg.ingest.sentry.io/project"

# PostHog (product analytics — client + server)
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-api-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Microsoft Clarity (session recordings, heatmaps)
NEXT_PUBLIC_CLARITY_ID="your-clarity-project-id"

# Environment
# NODE_ENV="development"
